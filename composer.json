{
    "name": "flametrench/ids",
    "description": "Prefixed wire-format IDs for Flametrench. UUIDv7 storage, self-describing public identifiers.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "flametrench",
        "uuid",
        "uuidv7",
        "identifier",
        "id"
    ],
    "homepage": "https://github.com/flametrench/laravel",
    "support": {
        "issues": "https://github.com/flametrench/laravel/issues",
        "source": "https://github.com/flametrench/laravel"
    },
    "authors": [
        {
            "name": "NDC Digital, LLC",
            "homepage": "https://flametrench.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Flametrench\\Ids\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flametrench\\Ids\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest"
    }
}
